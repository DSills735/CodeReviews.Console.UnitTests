  </ItemGroup>
	<ItemGroup>
		<InternalsVisibleTo Include="CodingTracker.Testing"></InternalsVisibleTo>
	</ItemGroup>

  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
